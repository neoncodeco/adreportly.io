# ── Database (Supabase → Project Settings → Database) ──
# Use pooler (6543) for app runtime; direct (5432) for Prisma migrations.
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# ── Supabase Auth (Project Settings → API) ──
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
# Required for middleware admin/ban checks and admin user deletion (server-only, never expose to browser)
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Supabase Dashboard → Authentication → URL configuration:
# Site URL + Redirect URLs must include https://your-domain/auth/callback

# ── App ──
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NODE_ENV=development

# ── Meta / Facebook OAuth (separate from Supabase Auth) ──
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
FACEBOOK_REDIRECT_URI="http://localhost:3000/api/auth/facebook/callback"
JWT_SECRET="min-16-chars-for-ar_agency-cookie"
ENCRYPTION_KEY="32-byte-key-for-meta-token-encryption"

# ── Billing (UddoktaPay) ──
UDDOKTAPAY_API_KEY=""
UDDOKTAPAY_BASE_URL="https://sandbox.uddoktapay.com/api/checkout-v2"
UDDOKTAPAY_WEBHOOK_SECRET=""

# ── SMTP (payment receipt emails only; auth emails handled by Supabase) ──
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
