# Copy to `.env` and fill in values.

# App URL — optional locally; set in production (e.g. https://yourdomain.com)
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# MongoDB — required for users, agencies, shared links (User.agencyId links app login ↔ Meta agency)
MONGODB_URI=mongodb://127.0.0.1:27017/ad_reportly

# Auth.js — required; generate: openssl rand -base64 32 (keep stable; min ~32 chars recommended)
AUTH_SECRET=
# Optional legacy name (same value as AUTH_SECRET if you use it):
# NEXTAUTH_SECRET=
#
# If the server logs JWTSessionError / "no matching decryption secret": your browser still has a
# session cookie encrypted with an OLD secret — clear cookies for localhost (or use a private
# window), then set AUTH_SECRET and restart `npm run dev`.

# Meta Developer App — required for Facebook login / ad accounts
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
# Optional; default is {SITE_URL}/api/auth/facebook/callback
# FACEBOOK_REDIRECT_URI=

# Min 16 chars each — required when using Meta OAuth (callback checks both)
JWT_SECRET=
ENCRYPTION_KEY=

# UddoktaPay recurring billing
# Base URL example: https://sandbox.uddoktapay.com
UDDOKTAPAY_BASE_URL=
UDDOKTAPAY_MERCHANT_ID=
UDDOKTAPAY_API_KEY=
UDDOKTAPAY_API_SECRET=
UDDOKTAPAY_WEBHOOK_SECRET=
